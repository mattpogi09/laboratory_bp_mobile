{
    "expo": {
        "name": "BP Diagnostic",
        "slug": "bp-diagnostic-laboratory",
        "version": "1.0.1",
        "orientation": "portrait",
        "icon": "./assets/images/Icon-Store-1024.png",
        "scheme": "laboratorybpmobile",
        "userInterfaceStyle": "automatic",
        "newArchEnabled": true,
        "ios": {
            "supportsTablet": true
        },
        "android": {
            "package": "com.laboratorybp.mobile",
            "adaptiveIcon": {
                "backgroundColor": "#ffffff",
                "foregroundImage": "./assets/images/Icon-Store-1024.png"
            },
            "edgeToEdgeEnabled": true,
            "predictiveBackGestureEnabled": false
        },
        "web": {
            "output": "static",
            "favicon": "./assets/images/favicon.png"
        },
        "plugins": [
            "expo-router",
            [
                "expo-splash-screen",
                {
                    "image": "./assets/images/Icon-Store-1024.png",
                    "imageWidth": 200,
                    "resizeMode": "contain",
                    "backgroundColor": "#ffffff",
                    "dark": {
                        "backgroundColor": "#ffffff"
                    }
                }
            ],
            "expo-secure-store",
            "@react-native-community/datetimepicker",
            "expo-font",
            "expo-web-browser"
        ],
        "experiments": {
            "typedRoutes": true,
            "reactCompiler": true
        },
        "extra": {
            "router": {},
            "eas": {
                "projectId": "c3b33c35-18f3-43af-9bcb-8fd0bd290f6f"
            }
        },
        "owner": "nexsmoshis-organization",
        "runtimeVersion": {
            "policy": "appVersion"
        },
        "updates": {
            "url": "https://u.expo.dev/c3b33c35-18f3-43af-9bcb-8fd0bd290f6f"
        }
    }
}
